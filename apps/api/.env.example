# Server
PORT=4000
# Comma-separated lista domena kojima CORS dozvoljava request-e.
# Lokalno: http://localhost:3000,http://localhost:3001
# Produkcija: https://kurs.spikoedu.rs,https://admin.spikoedu.rs
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

# Postgres (Supabase pooler)
# Za produkciju preporučeno: port 6543 (transaction mode) umesto 5432 (session mode)
# — multipleksira konekcije po transakciji, ne troši pool slot-ove.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase Auth (JWKS verifikacija)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_KEY=

# Bunny Stream (video hosting)
BUNNY_API_KEY=
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=
BUNNY_TOKEN_AUTH_KEY=

# Bunny Storage (audio + slike — odvojen servis od Stream-a)
# Setup: Bunny dashboard → Storage → Add Storage Zone → uzmi zone name + FTP password,
# pa Add Pull Zone za CDN URL.
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_PASSWORD=
BUNNY_STORAGE_CDN_HOSTNAME=
# Region: de (Falkenstein, default), ny, la, sg, syd, uk, se, br, jh
BUNNY_STORAGE_REGION=

# Google OAuth (rezervisano za buduću fazu — ostavi prazno za sada)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback

# Anthropic (Claude)
ANTHROPIC_API_KEY=
# Haiku — jeftin/brz, za AI tutor chat
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Sonnet — tačniji, za objašnjenje greške / generisanje kursa
ANTHROPIC_MODEL_SMART=claude-sonnet-5

# OpenAI — brz/jeftin word lookup (prevod reči). Ako je prazno, lookup pada nazad na Claude.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Email (rezervisano za buduću fazu — ostavi prazno za sada)
EMAIL_API_KEY=
EMAIL_FROM=no-reply@spikoedu.rs
